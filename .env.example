SERVER_PORT=8080

KAFKA_PORT=9092
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

POSTGRES_PORT=5432
POSTGRES_DB=mealsync
POSTGRES_USER=mealsync
POSTGRES_PASSWORD=mealsync

DB_URL=jdbc:postgresql://localhost:5432/mealsync
DB_USERNAME=mealsync
DB_PASSWORD=mealsync
DB_DRIVER=org.postgresql.Driver
JPA_DDL_AUTO=update

LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=DEBUG
LOG_LEVEL_SPRING_WEB=INFO
LOG_LEVEL_SPRING_KAFKA=INFO
LOG_LEVEL_APACHE_KAFKA=WARN
LOG_LEVEL_SQL=WARN
LOG_FILE=logs/mealsync.log
LOG_MAX_FILE_SIZE=10MB
LOG_MAX_HISTORY=14

SWAGGER_ENABLED=true
SWAGGER_API_DOCS_PATH=/v3/api-docs
SWAGGER_UI_PATH=/swagger-ui.html
